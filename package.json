{
  "name": "support-tickets-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "predev": "prisma generate",
    "dev": "next dev --port 3003",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "next start --port 3003",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "db:setup": "yarn prisma:generate && yarn db:push && yarn db:seed"
  },
  "dependencies": {
    "@prisma/client": "6.16.2",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "6.16.2",
    "typescript": "^5"
  }
}
